# Claude API-sleutel
ANTHROPIC_API_KEY=sk-ant-...

# Claude-modus
CLAUDE_MODEL=claude-sonnet-4-20250514

# VLAM-modus (UbiOps/Mistral)
VLAM_API_KEY=...
VLAM_BASE_URL=https://api...
VLAM_MODEL_ID=ubiops-deployment/...


# MCP-servers (pad naar server-scripts)
MCP_SERVER_KVK=../mcp/kvk/server.py
MCP_SERVER_KOOP=../mcp/koop/server.py
MCP_SERVER_REGELRECHT=../mcp/regelrecht/server.py
MCP_SERVER_RVO=../mcp/rvo/server.py

# Host-instellingen
VLAM_HOST=0.0.0.0
VLAM_PORT=8000

# Security
# CORS: komma-gescheiden whitelist. Leeg laten = "*" (alleen voor dev/POC).
# Voorbeeld prod: ALLOWED_ORIGINS=https://moza.overheid.nl,https://moza-test.overheid.nl
ALLOWED_ORIGINS=
# API-keys via request-headers accepteren (x-vlam-api-key / x-claude-api-key).
# Default: false. Zet op true voor demos waarin de frontend een eigen key meestuurt.
ALLOW_API_KEY_OVERRIDE=false
