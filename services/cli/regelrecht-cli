#!/usr/bin/env bash
# regelrecht-cli — CLI voor RegelRecht beslislogica
#
# Equivalent van mcp/servers/regelrecht/server.py
# Proxy naar de RegelRecht law execution engine (poc-machine-law)
# voor het toetsen van regelgeving.
#
# Gebruik:
#   regelrecht-cli check <kvk_nummer> [--elektriciteit <kwh>] [--gas <m3>] [--woonfunctie]
#   regelrecht-cli --help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/output.sh"
source "$SCRIPT_DIR/lib/provenance.sh"
source "$SCRIPT_DIR/lib/audit.sh"

# ---------------------------------------------------------------------------
# Configuratie
# ---------------------------------------------------------------------------

REGELRECHT_RPC_URL="${REGELRECHT_RPC_URL:-https://ui.lac.apps.digilab.network/mcp/rpc}"
REGELRECHT_SOURCE_LABEL="RegelRecht (poc-machine-law)"
REGELRECHT_VERSION="0.1.0"

# ---------------------------------------------------------------------------
# Globals
# ---------------------------------------------------------------------------

OPT_OUTPUT="pretty"
OPT_FIELDS=""
OPT_SELECT=""
OPT_PROVENANCE="false"
OPT_DRY_RUN="false"
ACTION=""
KVK_NUMMER=""

OPT_ELEKTRICITEIT=""
OPT_GAS=""
OPT_WOONFUNCTIE=""

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

show_help() {
    cat <<'EOF'
regelrecht-cli — CLI voor RegelRecht beslislogica

Gebruik:
  regelrecht-cli [opties] check <kvk_nummer>

Controleer of de Informatieplicht Energiebesparing van toepassing is
op een bedrijf. Gebruikt de beslislogica van het Besluit activiteiten
leefomgeving (artikelen 5.15 en 5.15d).

Parameters:
  <kvk_nummer>              KvK-nummer van het bedrijf (8 cijfers)

Optionele overrides:
  --elektriciteit <kwh>     Jaarlijks elektriciteitsverbruik (drempel: 50.000 kWh)
  --gas <m3>                Jaarlijks gasverbruik (drempel: 25.000 m3)
  --woonfunctie             Pand heeft uitsluitend woonfunctie (uitgezonderd)

Algemene opties:
  --fields <v1,v2>          Alleen opgegeven velden retourneren
  --select <jq-expr>        jq-filter toepassen op het resultaat
  --output <mode>           Uitvoerformaat: raw, pretty (standaard), table
  --provenance              Provenance metadata toevoegen
  --dry-run                 Toon het verzoek zonder uit te voeren
  --help                    Toon deze hulptekst

Voorbeelden:
  regelrecht-cli check 68750110
  regelrecht-cli check 68750110 --elektriciteit 60000 --gas 30000
  regelrecht-cli check 68750110 --fields voldoet_aan_voorwaarden,ontbrekende_gegevens
  regelrecht-cli check 68750110 --select '.wettelijke_grondslag[0]'
  regelrecht-cli check 68750110 --output table --fields wet,voldoet_aan_voorwaarden
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help; exit 0 ;;
            --fields) OPT_FIELDS="$2"; shift 2 ;;
            --select) OPT_SELECT="$2"; shift 2 ;;
            --output) OPT_OUTPUT="$2"; shift 2 ;;
            --provenance) OPT_PROVENANCE="true"; shift ;;
            --dry-run) OPT_DRY_RUN="true"; shift ;;
            --elektriciteit) OPT_ELEKTRICITEIT="$2"; shift 2 ;;
            --gas) OPT_GAS="$2"; shift 2 ;;
            --woonfunctie) OPT_WOONFUNCTIE="true"; shift ;;
            -*)
                echo "Onbekende optie: $1" >&2
                exit 1
                ;;
            *)
                if [[ -z "$ACTION" ]]; then
                    ACTION="$1"
                elif [[ -z "$KVK_NUMMER" ]]; then
                    KVK_NUMMER="$1"
                fi
                shift
                ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# RegelRecht check via JSON-RPC
# ---------------------------------------------------------------------------

do_check() {
    local kvk_nummer="$1"

    # Bouw parameters
    local law_params
    law_params=$(jq -n --arg kvk "$kvk_nummer" '{"KVK_NUMMER": $kvk}')

    # Bouw overrides
    local overrides="{}"
    local rvo_overrides="{}"
    local has_overrides=false

    if [[ -n "$OPT_ELEKTRICITEIT" ]]; then
        rvo_overrides=$(echo "$rvo_overrides" | jq --argjson v "$OPT_ELEKTRICITEIT" '. + {"JAARLIJKS_ELEKTRICITEITSVERBRUIK_KWH": $v}')
        has_overrides=true
    fi
    if [[ -n "$OPT_GAS" ]]; then
        rvo_overrides=$(echo "$rvo_overrides" | jq --argjson v "$OPT_GAS" '. + {"JAARLIJKS_GASVERBRUIK_M3": $v}')
        has_overrides=true
    fi
    if [[ "$OPT_WOONFUNCTIE" == "true" ]]; then
        rvo_overrides=$(echo "$rvo_overrides" | jq '. + {"IS_WOONFUNCTIE": true}')
        has_overrides=true
    fi

    if [[ "$has_overrides" == "true" ]]; then
        overrides=$(jq -n --argjson rvo "$rvo_overrides" '{"RVO": $rvo}')
    fi

    # Bouw RPC request
    local rpc_args
    rpc_args=$(jq -n \
        --argjson params "$law_params" \
        --argjson overrides "$overrides" \
        --arg has_overrides "$has_overrides" \
        '{
            service: "RVO",
            law: "omgevingswet/energiebesparing/informatieplicht",
            parameters: $params
        } + (if $has_overrides == "true" then {overrides: $overrides} else {} end)')

    local rpc_payload
    rpc_payload=$(jq -n \
        --argjson args "$rpc_args" \
        '{
            jsonrpc: "2.0",
            id: 1,
            method: "tools/call",
            params: {name: "execute_law", arguments: $args}
        }')

    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        echo "[dry-run] POST $REGELRECHT_RPC_URL"
        echo "[dry-run] Payload:"
        echo "$rpc_payload" | jq '.'
        exit 0
    fi

    # Voer RPC call uit
    local rpc_response
    rpc_response=$(curl -s --max-time 30 \
        -X POST "$REGELRECHT_RPC_URL" \
        -H "Content-Type: application/json" \
        -d "$rpc_payload")

    if [[ -z "$rpc_response" ]]; then
        echo '{"error":"SOURCE_UNAVAILABLE","message":"RegelRecht endpoint niet bereikbaar"}' >&2
        exit 2
    fi

    # Check voor RPC errors
    local rpc_error
    rpc_error=$(echo "$rpc_response" | jq -r '.error // empty')
    if [[ -n "$rpc_error" ]]; then
        echo "{\"error\":\"EXECUTION_ERROR\",\"message\":\"$rpc_error\"}" >&2
        exit 2
    fi

    # Extraheer en vereenvoudig het resultaat
    local response
    response=$(echo "$rpc_response" | python3 -c "
import sys, json

rpc = json.load(sys.stdin)
structured = rpc.get('result', {}).get('structuredContent', {})

if not structured:
    content = rpc.get('result', {}).get('content', [])
    text = ' '.join(c.get('text', '') for c in content if c.get('type') == 'text')
    print(json.dumps({'resultaat': text}))
    sys.exit(0)

result = {}

metadata = structured.get('law_metadata', {})
if metadata:
    result['wet'] = metadata.get('name', '')
    result['beschrijving'] = metadata.get('description', '').strip()
    result['service'] = metadata.get('service', '')

result['voldoet_aan_voorwaarden'] = structured.get('requirements_met', False)
result['uitkomsten'] = structured.get('output', {})

missing = structured.get('missing_parameters', [])
if missing:
    result['ontbrekende_gegevens'] = [
        {'naam': f.get('name', ''), 'beschrijving': f.get('description', '')}
        for entry in missing
        for f in entry.get('missing_fields', [])
    ]

rule_spec = structured.get('rule_spec', {})
defs = rule_spec.get('properties', {}).get('definitions', {})
if defs:
    result['drempelwaarden'] = defs

actions = rule_spec.get('actions', [])
if actions:
    grondslagen = []
    for action in actions:
        basis = action.get('legal_basis', {})
        if basis:
            grondslagen.append({
                'output': action.get('output', ''),
                'wet': basis.get('law', ''),
                'artikel': basis.get('article', ''),
                'url': basis.get('url', ''),
                'toelichting': basis.get('explanation', ''),
            })
    if grondslagen:
        result['wettelijke_grondslag'] = grondslagen

print(json.dumps(result, ensure_ascii=False))
")

    process_response "$response" "check" "$REGELRECHT_SOURCE_LABEL" "$REGELRECHT_VERSION"
}

# ---------------------------------------------------------------------------
# Response verwerking
# ---------------------------------------------------------------------------

process_response() {
    local response="$1"
    local tool_name="$2"
    local source_label="${3:-$REGELRECHT_SOURCE_LABEL}"
    local version="${4:-$REGELRECHT_VERSION}"

    audit_log "$tool_name" "$response"

    if [[ -n "$OPT_SELECT" ]]; then
        response=$(echo "$response" | jq "$OPT_SELECT")
    fi

    if [[ -n "$OPT_FIELDS" ]]; then
        response=$(apply_fields_filter "$response" "$OPT_FIELDS")
    fi

    if [[ "$OPT_PROVENANCE" == "true" ]]; then
        PROVENANCE_SOURCE="$source_label"
        CLI_VERSION="$version"
        response=$(wrap_provenance "$response")
    fi

    format_output "$response" "$OPT_OUTPUT"
}

# ---------------------------------------------------------------------------
# Routing
# ---------------------------------------------------------------------------

route_command() {
    case "$ACTION" in
        check)
            [[ -z "$KVK_NUMMER" ]] && { echo "KvK-nummer is verplicht." >&2; exit 1; }
            do_check "$KVK_NUMMER"
            ;;
        --help|-h|"") show_help ;;
        *) echo "Onbekende actie: $ACTION" >&2; exit 1 ;;
    esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    parse_args "$@"
    route_command
}

main "$@"
