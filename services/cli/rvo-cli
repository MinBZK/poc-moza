# ---------------------------------------------------------------------------
# Globals
# ---------------------------------------------------------------------------

OPT_OUTPUT="pretty"
OPT_FIELDS=""
OPT_SELECT=""
OPT_PROVENANCE="false"
OPT_DRY_RUN="false"
OPT_CONFIRM="false"
RESOURCE=""
ACTION=""
ARG1=""
ARG2=""
ARG3=""

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

show_help() {
    cat <<'EOF'
rvo-cli — CLI voor RVO subsidies en regelingen (mock)

Gebruik:
  rvo-cli [opties] <resource> <actie> [argumenten]

Resources en acties:
  regeling zoek <trefwoord>
    Zoek naar subsidies en regelingen op trefwoord.

  rapportage indienen <kvk_nummer> <regeling_id> <maatregel1,maatregel2,...>
    Dien een energiebesparingsrapportage in. MUTEREND — vereist --confirm.

Opties:
  --fields <v1,v2>     Alleen opgegeven velden retourneren
  --select <jq-expr>   jq-filter toepassen op het resultaat
  --output <mode>       Uitvoerformaat: raw, pretty (standaard), table
  --provenance          Provenance metadata toevoegen
  --dry-run             Toon het verzoek zonder uit te voeren
  --confirm             Bevestig muterende actie (vereist voor indienen)
  --help                Toon deze hulptekst

Voorbeelden:
  rvo-cli regeling zoek energiebesparing
  rvo-cli regeling zoek subsidie --fields naam,status,deadline --output table
  rvo-cli regeling zoek energie --select '[.resultaten[] | select(.status == "open")]'
  rvo-cli rapportage indienen 68750110 EBR-2026 "LED-verlichting,HR++ beglazing" --confirm
  rvo-cli rapportage indienen 68750110 EBR-2026 "LED-verlichting" --dry-run
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help; exit 0 ;;
            --fields) OPT_FIELDS="$2"; shift 2 ;;
            --select) OPT_SELECT="$2"; shift 2 ;;
            --output) OPT_OUTPUT="$2"; shift 2 ;;
            --provenance) OPT_PROVENANCE="true"; shift ;;
            --dry-run) OPT_DRY_RUN="true"; shift ;;
            --confirm) OPT_CONFIRM="true"; shift ;;
            -*)
                echo "Onbekende optie: $1" >&2
                exit 1
                ;;
            *)
                if [[ -z "$RESOURCE" ]]; then RESOURCE="$1"
                elif [[ -z "$ACTION" ]]; then ACTION="$1"
                elif [[ -z "$ARG1" ]]; then ARG1="$1"
                elif [[ -z "$ARG2" ]]; then ARG2="$1"
                elif [[ -z "$ARG3" ]]; then ARG3="$1"
                fi
                shift
                ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Zoek regeling
# ---------------------------------------------------------------------------

zoek_regeling() {
    local trefwoord="$1"

    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        echo "[dry-run] Zoek regelingen met trefwoord: $trefwoord"
        exit 0
    fi

    local trefwoord_lower
    trefwoord_lower=$(echo "$trefwoord" | tr '[:upper:]' '[:lower:]')

    local resultaten
    resultaten=$(echo "$MOCK_DATA" | jq --arg t "$trefwoord_lower" \
        '[.[] | select((.naam | ascii_downcase | contains($t)) or (.beschrijving | ascii_downcase | contains($t)))]')

    local aantal
    aantal=$(echo "$resultaten" | jq 'length')

    local response
    response=$(jq -n \
        --arg trefwoord "$trefwoord" \
        --argjson aantal "$aantal" \
        --argjson resultaten "$resultaten" \
        '{trefwoord: $trefwoord, aantal: $aantal, resultaten: $resultaten}')

    process_response "$response" "zoek_regeling"
}

# ---------------------------------------------------------------------------
# Indienen (MUTEREND)
# ---------------------------------------------------------------------------

indienen() {
    local kvk_nummer="$1"
    local regeling_id="$2"
    local maatregelen_csv="$3"

    # Validatie
    local missing=()
    [[ -z "$kvk_nummer" ]] && missing+=("kvk_nummer")
    [[ -z "$regeling_id" ]] && missing+=("regeling_id")
    [[ -z "$maatregelen_csv" ]] && missing+=("maatregelen")

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "{\"error\":\"ONTBREKENDE_VELDEN\",\"message\":\"Verplichte velden ontbreken: ${missing[*]}\"}" >&2
        exit 1
    fi

    # Converteer CSV naar JSON array
    local maatregelen
    maatregelen=$(echo "$maatregelen_csv" | jq -R 'split(",") | map(ltrimstr(" ") | rtrimstr(" "))')

    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        echo "[dry-run] MUTEREND: indienen rapportage"
        echo "[dry-run] KvK: $kvk_nummer"
        echo "[dry-run] Regeling: $regeling_id"
        echo "[dry-run] Maatregelen: $maatregelen_csv"
        echo "[dry-run] Gebruik --confirm om daadwerkelijk in te dienen."
        exit 0
    fi

    # Mutatie-beveiliging: vereist --confirm
    if [[ "$OPT_CONFIRM" != "true" ]]; then
        echo "FOUT: indienen is een muterende actie." >&2
        echo "Gebruik --dry-run om een preview te zien, of --confirm om in te dienen." >&2
        exit 1
    fi

    local referentienummer="RVO-${regeling_id}-${kvk_nummer}-001"
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

    local response
    response=$(jq -n \
        --arg status "INGEDIEND" \
        --arg ref "$referentienummer" \
        --arg kvk "$kvk_nummer" \
        --arg regeling "$regeling_id" \
        --argjson maatregelen "$maatregelen" \
        --arg ts "$timestamp" \
        '{
            status: $status,
            referentienummer: $ref,
            kvk_nummer: $kvk,
            regeling_id: $regeling,
            maatregelen: $maatregelen,
            ingediend_op: $ts,
            bevestiging: ("Uw rapportage voor " + $regeling + " is succesvol ingediend. U ontvangt een bevestiging op het e-mailadres dat gekoppeld is aan uw eHerkenning-account."),
            lopende_zaak: {
                referentienummer: $ref,
                zaak_type: "Energiebesparingsrapportage",
                regeling: $regeling,
                status: "In behandeling",
                ingediend_op: $ts,
                melding: ("Deze indiening is opgenomen als lopende zaak onder referentienummer " + $ref + ". U kunt de voortgang volgen op MijnOverheid Zakelijk onder Lopende zaken.")
            }
        }')

    process_response "$response" "indienen"
}

# ---------------------------------------------------------------------------
# Response verwerking
# ---------------------------------------------------------------------------

process_response() {
    local response="$1"
    local tool_name="$2"

    audit_log "$tool_name" "$response"

    if [[ -n "$OPT_SELECT" ]]; then
        response=$(echo "$response" | jq "$OPT_SELECT")
    fi

    if [[ -n "$OPT_FIELDS" ]]; then
        response=$(apply_fields_filter "$response" "$OPT_FIELDS")
    fi

    if [[ "$OPT_PROVENANCE" == "true" ]]; then
        PROVENANCE_SOURCE="$RVO_SOURCE_LABEL"
        CLI_VERSION="$RVO_VERSION"
        response=$(wrap_provenance "$response")
    fi

    format_output "$response" "$OPT_OUTPUT"
}

# ---------------------------------------------------------------------------
# Routing
# ---------------------------------------------------------------------------

route_command() {
    case "$RESOURCE" in
        regeling)
            case "$ACTION" in
                zoek)
                    [[ -z "$ARG1" ]] && { echo "Trefwoord is verplicht." >&2; exit 1; }
                    zoek_regeling "$ARG1"
                    ;;
                --help|-h) show_help ;;
                *) echo "Onbekende actie: $ACTION" >&2; exit 1 ;;
            esac
            ;;
        rapportage)
            case "$ACTION" in
                indienen)
                    indienen "$ARG1" "$ARG2" "$ARG3"
                    ;;
                --help|-h) show_help ;;
                *) echo "Onbekende actie: $ACTION" >&2; exit 1 ;;
            esac
            ;;
        --help|-h|"") show_help ;;
        *) echo "Onbekende resource: $RESOURCE" >&2; exit 1 ;;
    esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    parse_args "$@"
    route_command
}

main "$@"
