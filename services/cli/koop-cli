#!/usr/bin/env bash
# koop-cli — CLI voor de KOOP Regelingenbank (wet- en regelgeving)
#
# Equivalent van mcp/servers/koop/server.py
# Zoekt via de publieke SRU-zoekservice van overheid.nl en haalt
# volledige wetteksten op van wetten.nl.
#
# Gebruik:
#   koop-cli regeling zoek <trefwoord> [--onderwerp <x>] [--type <x>] [--max <n>]
#   koop-cli regeling get <bwb_id>
#   koop-cli --help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/output.sh"
source "$SCRIPT_DIR/lib/provenance.sh"
source "$SCRIPT_DIR/lib/audit.sh"

# ---------------------------------------------------------------------------
# Configuratie
# ---------------------------------------------------------------------------

KOOP_SRU_URL="${KOOP_SRU_URL:-https://zoekservice.overheid.nl/sru/Search}"
KOOP_SRU_CONNECTION="${KOOP_SRU_CONNECTION:-BWB}"
KOOP_SOURCE_LABEL="KOOP Regelingenbank"
KOOP_VERSION="0.1.0"

# ---------------------------------------------------------------------------
# Globals
# ---------------------------------------------------------------------------

OPT_OUTPUT="pretty"
OPT_FIELDS=""
OPT_SELECT=""
OPT_PROVENANCE="false"
OPT_DRY_RUN="false"
RESOURCE=""
ACTION=""
POSITIONAL_ARG=""

# Extra opties voor zoeken
OPT_ONDERWERP=""
OPT_TYPE=""
OPT_MAX="10"

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

show_help() {
    cat <<'EOF'
koop-cli — CLI voor de KOOP Regelingenbank

Gebruik:
  koop-cli [opties] regeling <actie> [argument]

Acties:
  zoek <trefwoord>    Zoek wet- en regelgeving op trefwoord
  get <bwb_id>        Haal volledige wettekst op (bijv. BWBR0001840 = Grondwet)

Zoekopties:
  --onderwerp <x>     Filter op rechtsgebied (bijv. energie, milieu)
  --type <x>          Filter op type: wet, AMvB, ministerieleregeling, verdrag
  --max <n>           Max resultaten (standaard 10, max 50)

Algemene opties:
  --fields <v1,v2>    Alleen opgegeven velden retourneren
  --select <jq-expr>  jq-filter toepassen op het resultaat
  --output <mode>     Uitvoerformaat: raw, pretty (standaard), table
  --provenance        Provenance metadata toevoegen
  --dry-run           Toon het verzoek zonder uit te voeren
  --help              Toon deze hulptekst

Voorbeelden:
  koop-cli regeling zoek energiebesparing
  koop-cli regeling zoek energie --type wet --max 5 --output table
  koop-cli regeling zoek milieu --fields titel,identifier,type
  koop-cli regeling get BWBR0001840
  koop-cli regeling get BWBR0001840 --fields titel,aantal_artikelen
  koop-cli regeling get BWBR0001840 --select '.artikelen[0]'
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help; exit 0 ;;
            --fields) OPT_FIELDS="$2"; shift 2 ;;
            --select) OPT_SELECT="$2"; shift 2 ;;
            --output) OPT_OUTPUT="$2"; shift 2 ;;
            --provenance) OPT_PROVENANCE="true"; shift ;;
            --dry-run) OPT_DRY_RUN="true"; shift ;;
            --onderwerp) OPT_ONDERWERP="$2"; shift 2 ;;
            --type) OPT_TYPE="$2"; shift 2 ;;
            --max) OPT_MAX="$2"; shift 2 ;;
            -*)
                echo "Onbekende optie: $1" >&2
                exit 1
                ;;
            *)
                if [[ -z "$RESOURCE" ]]; then
                    RESOURCE="$1"
                elif [[ -z "$ACTION" ]]; then
                    ACTION="$1"
                elif [[ -z "$POSITIONAL_ARG" ]]; then
                    POSITIONAL_ARG="$1"
                fi
                shift
                ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# SRU zoeken
# ---------------------------------------------------------------------------

sru_zoek() {
    local trefwoord="$1"

    # Bouw CQL-query
    local query_parts=()
    [[ -n "$trefwoord" ]] && query_parts+=("overheidbwb.titel any \"$trefwoord\"")
    [[ -n "$OPT_ONDERWERP" ]] && query_parts+=("overheidbwb.rechtsgebied = \"$OPT_ONDERWERP\"")
    [[ -n "$OPT_TYPE" ]] && query_parts+=("dcterms.type = \"$OPT_TYPE\"")

    local query
    query=$(IFS=" AND "; echo "${query_parts[*]}")

    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        echo "[dry-run] GET $KOOP_SRU_URL"
        echo "[dry-run] Query: $query"
        echo "[dry-run] Max: $OPT_MAX"
        exit 0
    fi

    local xml
    xml=$(curl -s --max-time 15 \
        --get "$KOOP_SRU_URL" \
        --data-urlencode "version=2.0" \
        --data-urlencode "operation=searchRetrieve" \
        --data-urlencode "x-connection=$KOOP_SRU_CONNECTION" \
        --data-urlencode "query=$query" \
        --data-urlencode "maximumRecords=$OPT_MAX" \
        -H "Accept: text/xml")

    if [[ -z "$xml" ]]; then
        echo '{"error":"SOURCE_UNAVAILABLE","message":"SRU-zoekservice niet bereikbaar"}' >&2
        exit 2
    fi

    # Parse XML naar JSON met een inline XSLT-achtige benadering via xmllint + jq
    # We gebruiken een pragmatische aanpak: grep + sed voor de relevante velden
    local response
    response=$(echo "$xml" | parse_sru_to_json "$query")

    process_response "$response" "regeling.zoek" "$KOOP_SOURCE_LABEL" "$KOOP_VERSION"
}

parse_sru_to_json() {
    local query="$1"
    local xml
    xml=$(cat)

    # Extract records met basis string processing (geen lxml nodig)
    local results="[]"
    local seen_ids=""

    # Gebruik python3 als het beschikbaar is (voor XML parsing), anders fallback
    if command -v python3 &>/dev/null; then
        results=$(python3 -c "
import sys, json
from xml.etree import ElementTree as ET

xml_str = sys.stdin.read()
root = ET.fromstring(xml_str)

ns = {
    'sru': 'http://docs.oasis-open.org/ns/search-ws/sruResponse',
    'dcterms': 'http://purl.org/dc/terms/',
    'overheid': 'http://standaarden.overheid.nl/owms/terms/',
    'overheidbwb': 'http://standaarden.overheid.nl/bwb/terms/',
}

results = []
seen = set()

for record in root.iter('{http://docs.oasis-open.org/ns/search-ws/sruResponse}record'):
    data = record.find('.//sru:recordData', ns)
    if data is None:
        continue
    entry = {}
    id_el = data.find('.//{http://purl.org/dc/terms/}identifier')
    if id_el is not None and id_el.text:
        bwb_id = id_el.text.strip()
        if bwb_id in seen:
            continue
        seen.add(bwb_id)
        entry['identifier'] = bwb_id

    for tag, key in [('title', 'titel'), ('type', 'type'), ('creator', 'organisatie')]:
        el = data.find('.//{http://purl.org/dc/terms/}' + tag)
        if el is not None and el.text:
            entry[key] = el.text.strip()

    auth = data.find('.//{http://standaarden.overheid.nl/owms/terms/}authority')
    if auth is not None and auth.text:
        entry['verantwoordelijke'] = auth.text.strip()

    rg = data.find('.//{http://standaarden.overheid.nl/bwb/terms/}rechtsgebied')
    if rg is not None and rg.text:
        entry['rechtsgebied'] = rg.text.strip()

    start = data.find('.//{http://standaarden.overheid.nl/bwb/terms/}geldigheidsperiode_startdatum')
    if start is not None and start.text:
        entry['geldig_vanaf'] = start.text.strip()

    if entry:
        results.append(entry)

print(json.dumps(results, ensure_ascii=False))
" <<< "$xml")
    else
        echo '{"error":"MISSING_DEPENDENCY","message":"python3 is vereist voor XML parsing"}' >&2
        exit 1
    fi

    local aantal
    aantal=$(echo "$results" | jq 'length')

    jq -n \
        --argjson resultaten "$results" \
        --arg aantal "$aantal" \
        --arg query "$query" \
        '{resultaten: $resultaten, aantal: ($aantal | tonumber), zoekopdracht: $query}'
}

# ---------------------------------------------------------------------------
# Regeling ophalen (volledige tekst)
# ---------------------------------------------------------------------------

regeling_get() {
    local bwb_id="$1"

    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        echo "[dry-run] SRU lookup: $bwb_id -> toestand URL"
        echo "[dry-run] GET https://wetten.overheid.nl/..."
        exit 0
    fi

    # Stap 1: Zoek de toestand-URL op via SRU
    local sru_xml
    sru_xml=$(curl -s --max-time 15 \
        --get "$KOOP_SRU_URL" \
        --data-urlencode "version=2.0" \
        --data-urlencode "operation=searchRetrieve" \
        --data-urlencode "x-connection=$KOOP_SRU_CONNECTION" \
        --data-urlencode "query=dcterms.identifier = \"$bwb_id\"" \
        --data-urlencode "maximumRecords=1" \
        -H "Accept: text/xml")

    if [[ -z "$sru_xml" ]]; then
        echo '{"error":"SOURCE_UNAVAILABLE","message":"SRU-zoekservice niet bereikbaar"}' >&2
        exit 2
    fi

    # Extract toestand URL en haal de volledige XML op
    local response
    response=$(python3 -c "
import sys, json
from xml.etree import ElementTree as ET

xml_str = sys.stdin.read()
root = ET.fromstring(xml_str)

ns = {'sru': 'http://docs.oasis-open.org/ns/search-ws/sruResponse'}
bwb_ns = 'http://standaarden.overheid.nl/bwb/terms/'

# Zoek toestand URL
xml_url = None
for record in root.iter('{http://docs.oasis-open.org/ns/search-ws/sruResponse}record'):
    data = record.find('.//sru:recordData', ns)
    if data is None:
        continue
    loc = data.find('.//{%s}locatie_toestand' % bwb_ns)
    if loc is not None and loc.text:
        xml_url = loc.text.strip()
        break

if not xml_url:
    print(json.dumps({'error': 'NIET_GEVONDEN', 'message': f'Geen toestand gevonden voor BWB-ID: $bwb_id'}))
    sys.exit(0)

# Haal de volledige regeling op
import urllib.request
req = urllib.request.Request(xml_url, headers={'Accept': 'text/xml'})
with urllib.request.urlopen(req, timeout=15) as resp:
    reg_xml = resp.read()

reg_root = ET.fromstring(reg_xml)
result = {'bwb_id': '$bwb_id'}

# Titel
for tag in ['intitule', '{*}intitule']:
    el = reg_root.find(f'.//{tag}')
    if el is not None and el.text:
        result['titel'] = el.text.strip()
        break

# Artikelen
artikelen = []
for artikel in reg_root.iter('{*}artikel'):
    nummer = artikel.get('nr', '')
    tekst = ' '.join(artikel.itertext()).strip()
    if tekst:
        artikelen.append({'nummer': nummer, 'tekst': tekst})

if artikelen:
    result['artikelen'] = artikelen
    result['aantal_artikelen'] = len(artikelen)
else:
    all_text = ' '.join(reg_root.itertext()).strip()
    if len(all_text) > 5000:
        all_text = all_text[:5000] + '... [ingekort]'
    result['tekst'] = all_text

print(json.dumps(result, ensure_ascii=False))
" <<< "$sru_xml")

    # Check of het een error is
    if echo "$response" | jq -e '.error' &>/dev/null; then
        echo "$response" >&2
        exit 1
    fi

    process_response "$response" "regeling.get" "$KOOP_SOURCE_LABEL" "$KOOP_VERSION"
}

# ---------------------------------------------------------------------------
# Response verwerking
# ---------------------------------------------------------------------------

process_response() {
    local response="$1"
    local tool_name="$2"
    local source_label="${3:-$KOOP_SOURCE_LABEL}"
    local version="${4:-$KOOP_VERSION}"

    audit_log "$tool_name" "$response"

    if [[ -n "$OPT_SELECT" ]]; then
        response=$(echo "$response" | jq "$OPT_SELECT")
    fi

    if [[ -n "$OPT_FIELDS" ]]; then
        response=$(apply_fields_filter "$response" "$OPT_FIELDS")
    fi

    if [[ "$OPT_PROVENANCE" == "true" ]]; then
        PROVENANCE_SOURCE="$source_label"
        CLI_VERSION="$version"
        response=$(wrap_provenance "$response")
    fi

    format_output "$response" "$OPT_OUTPUT"
}

# ---------------------------------------------------------------------------
# Routing
# ---------------------------------------------------------------------------

route_command() {
    case "$RESOURCE" in
        regeling)
            case "$ACTION" in
                zoek)
                    [[ -z "$POSITIONAL_ARG" ]] && { echo "Trefwoord is verplicht." >&2; exit 1; }
                    sru_zoek "$POSITIONAL_ARG"
                    ;;
                get)
                    [[ -z "$POSITIONAL_ARG" ]] && { echo "BWB-ID is verplicht." >&2; exit 1; }
                    regeling_get "$POSITIONAL_ARG"
                    ;;
                --help|-h) show_help ;;
                *) echo "Onbekende actie: $ACTION" >&2; exit 1 ;;
            esac
            ;;
        --help|-h|"") show_help ;;
        *) echo "Onbekende resource: $RESOURCE" >&2; exit 1 ;;
    esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    parse_args "$@"
    route_command
}

main "$@"
