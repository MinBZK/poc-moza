#!/usr/bin/env bash
# kvk-cli — CLI voor de KvK API, gebouwd naast de MCP-server als vergelijkingstest.
#
# Volgt het moneybird-cli patroon: Bash + jq, --fields filtering, --output modes.
# Voegt provenance en audit logging toe conform de MCP-standaard voor de overheid.
#
# Gebruik:
#   kvk-cli basisprofiel get [kvk_nummer]
#   kvk-cli basisprofiel vestigingen [kvk_nummer]
#   kvk-cli basisprofiel eigenaar [kvk_nummer]
#   kvk-cli --help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Laad modules
source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/request.sh"
source "$SCRIPT_DIR/lib/output.sh"
source "$SCRIPT_DIR/lib/provenance.sh"
source "$SCRIPT_DIR/lib/audit.sh"

# ---------------------------------------------------------------------------
# Globals (gezet door argument parsing)
# ---------------------------------------------------------------------------
OPT_OUTPUT="pretty"
OPT_FIELDS=""
OPT_SELECT=""
OPT_PROVENANCE="false"
OPT_DRY_RUN="false"
RESOURCE=""
ACTION=""
RESOURCE_ID=""

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

show_help() {
    cat <<'EOF'
kvk-cli — CLI voor de KvK API

Gebruik:
  kvk-cli [opties] <resource> <actie> [id]

Resources:
  basisprofiel    Bedrijfsgegevens uit het Handelsregister

Acties:
  get             Haal basisprofiel op (standaard: sessie-gebonden KvK-nummer)
  vestigingen     Toon vestigingen van het bedrijf
  eigenaar        Toon eigenaar-informatie

Opties:
  --fields <v1,v2>     Alleen opgegeven velden retourneren
  --select <jq-expr>   jq-filter toepassen op het resultaat
  --output <mode>      Uitvoerformaat: raw, pretty (standaard), table
  --provenance         Provenance metadata toevoegen (MCP-standaard §4.1)
  --dry-run            Toon het API-verzoek zonder uit te voeren
  --help               Toon deze hulptekst

Voorbeelden:
  kvk-cli basisprofiel get
  kvk-cli basisprofiel get 68750110 --fields naam,kvkNummer --output table
  kvk-cli basisprofiel get --fields sbiActiviteiten --output raw
  kvk-cli basisprofiel vestigingen --fields eersteHandelsnaam,adressen
  kvk-cli basisprofiel get --select '._embedded.hoofdvestiging.adressen[0]'
  kvk-cli basisprofiel get --provenance --fields naam

Omgevingsvariabelen:
  KVK_API_KEY          API-sleutel (standaard: KvK test-key)
  KVK_API_BASE         API base-URL (standaard: https://api.kvk.nl/test/api)
  KVK_SESSIE_NUMMER    Sessie-gebonden KvK-nummer (standaard: 68750110)
  KVK_AUDIT_LOG        Pad naar auditlog (standaard: stderr)
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_help
                exit 0
                ;;
            --fields)
                OPT_FIELDS="$2"
                shift 2
                ;;
            --select)
                OPT_SELECT="$2"
                shift 2
                ;;
            --output)
                OPT_OUTPUT="$2"
                shift 2
                ;;
            --provenance)
                OPT_PROVENANCE="true"
                shift
                ;;
            --dry-run)
                OPT_DRY_RUN="true"
                shift
                ;;
            -*)
                echo "Onbekende optie: $1" >&2
                echo "Gebruik --help voor hulp." >&2
                exit 1
                ;;
            *)
                if [[ -z "$RESOURCE" ]]; then
                    RESOURCE="$1"
                elif [[ -z "$ACTION" ]]; then
                    ACTION="$1"
                elif [[ -z "$RESOURCE_ID" ]]; then
                    RESOURCE_ID="$1"
                else
                    echo "Te veel argumenten: $1" >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Command routing
# ---------------------------------------------------------------------------

route_command() {
    local kvk_nummer="${RESOURCE_ID:-$KVK_SESSIE_NUMMER}"

    # Beveiligingscheck: alleen eigen KvK-nummer (sessie-gebonden)
    if [[ "$kvk_nummer" != "$KVK_SESSIE_NUMMER" ]]; then
        echo '{"error":"NIET_TOEGESTAAN","message":"U kunt alleen uw eigen bedrijfsgegevens inzien."}' >&2
        audit_log "SECURITY" "{\"poging\":\"$kvk_nummer\",\"sessie\":\"$KVK_SESSIE_NUMMER\"}"
        exit 1
    fi

    case "$RESOURCE" in
        basisprofiel)
            case "$ACTION" in
                get|"")
                    local path="/v1/basisprofielen/$kvk_nummer"
                    local response
                    response=$(kvk_request "$path")
                    process_response "$response" "basisprofiel.get"
                    ;;
                vestigingen)
                    local path="/v1/basisprofielen/$kvk_nummer/vestigingen"
                    local response
                    response=$(kvk_request "$path")
                    process_response "$response" "basisprofiel.vestigingen"
                    ;;
                eigenaar)
                    local path="/v1/basisprofielen/$kvk_nummer/eigenaar"
                    local response
                    response=$(kvk_request "$path")
                    process_response "$response" "basisprofiel.eigenaar"
                    ;;
                --help|-h)
                    cat <<'EOF'
kvk-cli basisprofiel — Bedrijfsgegevens uit het Handelsregister

Acties:
  get [kvk_nummer]          Haal basisprofiel op
  vestigingen [kvk_nummer]  Toon vestigingen
  eigenaar [kvk_nummer]     Toon eigenaar-informatie

Beschikbare velden (basisprofiel get):
  kvkNummer, naam, statutaireNaam, formeleRegistratiedatum,
  totaalWerkzamePersonen, sbiActiviteiten, handelsnamen,
  _embedded.hoofdvestiging, _embedded.eigenaar, indNonMailing
EOF
                    ;;
                *)
                    echo "Onbekende actie: $ACTION" >&2
                    echo "Gebruik: kvk-cli basisprofiel --help" >&2
                    exit 1
                    ;;
            esac
            ;;
        --help|-h|"")
            show_help
            ;;
        *)
            echo "Onbekende resource: $RESOURCE" >&2
            echo "Gebruik --help voor beschikbare resources." >&2
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Response verwerking (filter → select → provenance → format)
# ---------------------------------------------------------------------------

process_response() {
    local response="$1"
    local tool_name="$2"

    # Audit log
    audit_log "$tool_name" "$response"

    # Stap 1: --select (jq expressie) — selecteer eerst de relevante data
    if [[ -n "$OPT_SELECT" ]]; then
        response=$(echo "$response" | jq "$OPT_SELECT")
    fi

    # Stap 2: --fields filtering — filter daarna de velden
    if [[ -n "$OPT_FIELDS" ]]; then
        response=$(apply_fields_filter "$response" "$OPT_FIELDS")
    fi

    # Stap 3: provenance toevoegen (opt-in)
    if [[ "$OPT_PROVENANCE" == "true" ]]; then
        response=$(wrap_provenance "$response")
    fi

    # Stap 4: output formatting
    format_output "$response" "$OPT_OUTPUT"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    parse_args "$@"

    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        local kvk_nummer="${RESOURCE_ID:-$KVK_SESSIE_NUMMER}"
        echo "[dry-run] GET ${KVK_API_BASE}/v1/basisprofielen/$kvk_nummer"
        echo "[dry-run] Headers: apikey: ${KVK_API_KEY:0:8}..."
        [[ -n "$OPT_FIELDS" ]] && echo "[dry-run] Fields: $OPT_FIELDS"
        [[ -n "$OPT_SELECT" ]] && echo "[dry-run] Select: $OPT_SELECT"
        exit 0
    fi

    route_command
}

main "$@"
