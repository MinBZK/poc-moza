<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="{{ '/style/style.css' | url }}">
    <meta name="description" content="{{ description | default('MijnOverheid Zakelijk') }}">
    <link rel="shortcut icon" href="{{ '/assets/favicon/favicon.ico' | url }}" type="image/x-icon">
    <link rel="icon" sizes="192x192" href="{{ '/assets/favicon/touch-icon.png' | url }}">
    <link rel="apple-touch-icon" href="{{ '/assets/favicon/apple-touch-icon.png' | url }}">
    {% block extraStyles %}{% endblock %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

    {% if headerType == "overheid" %}
        {% include "header-overheid.njk" %}
    {% elif headerType == "overheid-uitgelogd" %}
        {% include "header-overheid-uitgelogd.njk" %}
    {% elif headerType == "mobu" %}
        {% include "header-mobu.njk" %}
    {% elif headerType == "mobu-uitgelogd" %}
        {% include "header-mobu-uitgelogd.njk" %}
    {% else %}
        {% include "header-rijksoverheid.njk" %}
    {% endif %}

    <main>
        {{ content | safe }}
    </main>

    {% if footerType == "overheid" %}
        {% include "footer-overheid.njk" %}
    {% elif footerType == "mobu" %}
        {% include "footer-mobu.njk" %}
    {% else %}
    <footer></footer>
    {% endif %}

    <script src="{{ '/assets/javascript/aria-disabled.js' | url }}"></script>
    <script src="{{ '/assets/javascript/indeterminate.js' | url }}"></script>
    <script src="{{ '/assets/javascript/account-switcher.js' | url }}"></script>
    <script src="{{ '/assets/javascript/content-interactions.js' | url }}"></script>
    <script src="{{ '/assets/javascript/feature-flags.js' | url }}"></script>
    <script src="{{ '/assets/javascript/berichtenbox.js' | url }}"></script>
</body>
</html>