<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="{{ '/style/style.css' | url }}">
    <meta name="description" content="{{ description | default('MijnOverheid Zakelijk') }}">
    <link rel="shortcut icon" href="{{ '/assets/favicon/favicon.ico' | url }}" type="image/x-icon">
    <link rel="icon" sizes="192x192" href="{{ '/assets/favicon/touch-icon.png' | url }}">
    <link rel="apple-touch-icon" href="{{ '/assets/favicon/apple-touch-icon.png' | url }}">
    {% if extraStyles %}{{ extraStyles | safe }}{% endif %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

    {% if headerType == "overheid" %}
        {% include "header-overheid.njk" %}
    {% elif headerType == "overheid-uitgelogd" %}
        {% include "header-overheid-uitgelogd.njk" %}
    {% elif headerType == "mobu" %}
        {% include "header-mobu.njk" %}
    {% elif headerType == "mobu-uitgelogd" %}
        {% include "header-mobu-uitgelogd.njk" %}
    {% elif headerType != "none" %}
        {% include "header-rijksoverheid.njk" %}
    {% endif %}

    <main>
        {{ content | safe }}
    </main>

    {% if footerType == "overheid" %}
        {% include "footer-overheid.njk" %}
    {% elif footerType == "mobu" %}
        {% include "footer-mobu.njk" %}
    {% elif footerType != "none" %}
    <footer></footer>
    {% endif %}

    <script>window.PATH_PREFIX = "{{ '/' | url }}";</script>
    <script src="{{ '/assets/javascript/aria-disabled.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/indeterminate.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/account-switcher.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/content-interactions.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/feature-flags.js' | url }}" defer></script>
    <script>window.testprofielenData = {{ testprofielen | dump | safe }};</script>
    <script>window.subsidiesData = {{ subsidiesData | dump | safe }};</script>
    <script>window.regelgevingData = {{ regelgevingData | dump | safe }};</script>
    <script src="{{ '/assets/javascript/testprofielen.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/homepage-profiel.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/tab-interface.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/external-links.js' | url }}" defer></script>
    <script src="{{ '/assets/javascript/berichtenbox.js' | url }}" defer></script>

</body>
</html>
