---
pagination:
  data: subsidiesData
  size: 1
  alias: subsidie
permalink: "/moza/subsidies/{{ subsidie.id }}/"
eleventyComputed:
  title: "MijnOverheid Zakelijk: {{ subsidie.titel }}"
subNavActive: "/moza/actueel/"
---

{% include "side-nav-overheid.njk" %}

<article id="hoofd-inhoud">
	<nav class="breadcrumb">
		<ol>
			<li><a href="{{ '/moza/' | url }}">Home</a></li>
			<li><a href="{{ '/moza/subsidies/' | url }}">Subsidies en financiering</a></li>
			<li aria-current="page">{{ subsidie.titel }}</li>
		</ol>
	</nav>

	<h1>{{ subsidie.titel }}</h1>

	<a href="{{ '/moza/subsidies/' | url }}" class="back-link">Terug naar Subsidies en financiering</a>

	<section class="card">
		<p class="intro">{{ subsidie.beschrijving }}</p>

		<dl class="data-overview">
			<dt>Verstrekker</dt>
			<dd>{{ subsidie.verstrekker }}</dd>
			<dt>Type</dt>
			<dd>{{ subsidie.type }}</dd>
			<dt>Aanvraagperiode</dt>
			<dd>{{ subsidie.aanvraagperiode }}</dd>
			{% if subsidie.maximaalBedrag %}
			<dt>Maximaal bedrag</dt>
			<dd>{{ subsidie.maximaalBedrag }}</dd>
			{% endif %}
			{% if subsidie.budgetVergeven %}
			<dt>Budget vergeven</dt>
			<dd>
				<div class="progress-bar" role="progressbar" aria-label="Budget vergeven" aria-valuenow="{{ subsidie.budgetVergeven }}" aria-valuemin="0" aria-valuemax="100">
					<div class="progress-bar-fill" style="inline-size: {{ subsidie.budgetVergeven }}%">{{ subsidie.budgetVergeven }}%</div>
				</div>
			</dd>
			{% endif %}
		</dl>

		{% for alinea in subsidie.inhoud %}
		<p>{{ alinea }}</p>
		{% endfor %}

		{% include "action-group.njk" %}

		<div class="action-group">
			<a class="btn-cta" href="{{ subsidie.externUrl }}" rel="external">Bekijk op de website van {{ subsidie.verstrekker }}</a>
		</div>
	</section>
</article>
