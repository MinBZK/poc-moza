{
	"name": "mox",
	"private": true,
	"scripts": {
		"build": "cd style-dictionary && npm run build && cd .. && npx @11ty/eleventy",
		"dev": "concurrently --names \"eleventy,tokens,backend\" -c \"cyan,magenta,yellow\" \"npx @11ty/eleventy --watch\" \"chokidar 'tokens/tokens.json' -c 'cd style-dictionary && npm run build'\" \"cd services/host && python api.py\"",
		"tokens": "cd style-dictionary && npm run build",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build -o _site/storybook",
		"lint:css": "stylelint 'style/**/*.css'",
		"lint:css:fix": "stylelint 'style/**/*.css' --fix"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/html-vite": "^10.3.5",
		"chokidar-cli": "^3.0.0",
		"chromatic": "^15.2.0",
		"concurrently": "^9.1.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"storybook": "^10.3.5",
		"stylelint": "^17.4.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-order": "^8.1.1",
		"stylelint-use-logical": "^2.1.3",
		"vite": "^6.0.0"
	}
}
