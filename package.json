{
	"name": "moza-mockups",
	"private": true,
	"scripts": {
		"dev": "concurrently \"astro dev\" \"chokidar 'tokens/tokens.json' -c 'npm run build:tokens'\"",
		"build": "npm run build:tokens && astro build",
		"build:tokens": "node tokens/style-dictionary.config.mjs",
		"preview": "astro preview",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@astrojs/react": "^4.0.0",
		"astro": "^5.0.0",
		"mox-nlds": "github:MinBZK/moza-mox-nlds",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@storybook/addon-a11y": "^10.2.14",
		"@storybook/html-vite": "^10.2.14",
		"@tokens-studio/sd-transforms": "^2.0.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"chokidar-cli": "^3.0.0",
		"concurrently": "^9.1.2",
		"storybook": "^10.2.14",
		"style-dictionary": "^5.2.0",
		"stylelint": "^17.4.0",
		"stylelint-use-logical": "^2.1.3",
		"vite": "^6.0.0"
	}
}
